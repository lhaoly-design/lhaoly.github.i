flowchart LR
  %% 承载力群控群调：泳道图（无分支）

  subgraph L1[供电局端]
    G1[上传4类Excel] --> G2[发起分析请求]
    G3[确认调度]
    G4[接收业主通知结果]
    G5[接收调度结果]
  end

  subgraph L2[运营端]
    O1[接收请求] --> O2[分析生成报告]
    O3[发送业主通知]
    O4[开始调度]
    O5[调度完成]
  end

  subgraph L3[业主端]
    B1[确认/拒绝通知]
  end

  %% 线性连接
  G2 --> O1
  O2 --> G3
  G3 --> O3
  O3 --> B1
  B1 --> G4
  G4 --> O4
  O4 --> O5
  O5 --> G5
